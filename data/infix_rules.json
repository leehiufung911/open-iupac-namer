        {"alias": "tellur", "opsin_from": "=O,-O", "opsin_to": "[Te]", "replaces_oh": false, "class_word": null, "ic_stem": "tellur", "applicable_to": ["carboxylic_acid"]},
        {"alias": "thi", "opsin_from": "=O,-O", "opsin_to": "S", "replaces_oh": false, "class_word": null, "ic_stem": "thi", "applicable_to": ["carboxylic_acid"], "covered_via": "functional_groups.json"},
        {"alias": "thiocyanatid", "opsin_from": "-O", "opsin_to": "SC#N", "replaces_oh": true, "class_word": "thiocyanate", "ic_stem": null, "applicable_to": ["carboxylic_acid"]},
        {"alias": "selenocyanatid", "opsin_from": "-O", "opsin_to": "[Se]C#N", "replaces_oh": true, "class_word": "selenocyanate", "ic_stem": null, "applicable_to": ["carboxylic_acid"]},
        {"alias": "tellurocyanatid", "opsin_from": "-O", "opsin_to": "[Te]C#N", "replaces_oh": true, "class_word": "tellurocyanate", "ic_stem": null, "applicable_to": ["carboxylic_acid"]},
        {"alias": "hydroxim", "opsin_from": "=O", "opsin_to": "=NO", "replaces_oh": false, "class_word": null, "ic_stem": "hydroxim", "applicable_to": ["carboxylic_acid"], "iupac_retired": true}
    ]
