    "CC(N)=NO": {
      "name": "acetamidoxime",
      "source": "iupac_p66",
      "rule": "P-66.4 retains 'acetamidoxime' as the PIN for CH3-C(=N-OH)-NH2 (amidoxime = N-hydroxyamidine). Engine otherwise emits substitutive '1-(hydroxyimino)ethanamine'; whole-molecule canonical-SMILES match. OPSIN round-trips: acetamidoxime -> CC(N)=NO (canonical match)."
    },
    "O=C1CCC(=O)N1": {
      "name": "succinimide",
      "source": "iupac_p66",
      "rule": "P-66.2 retains 'succinimide' as the PIN for the cyclic imide of succinic acid (1H-pyrrole-2,5-dione, fully reduced ring). Engine otherwise emits the substitutive '2,5-dioxopyrrolidine' form; whole-molecule canonical-SMILES match. OPSIN round-trips: succinimide -> O=C1CCC(=O)N1 (canonical match)."
    },
